APP_NAME=AI-Native PMS Backend
API_PREFIX=/api/v1
# Local development (backend running on host machine)
DATABASE_URL=postgresql+asyncpg://postgres:shiv@localhost:5432/pms
# Docker compose backend service should use:
# DATABASE_URL=postgresql+asyncpg://postgres:shiv@db:5432/pms
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
JWT_SECRET=super-secret-change-me
JWT_SECRET_KEY=super-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=14
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar,https://www.googleapis.com/auth/calendar.events
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth2callback
SESSION_SECRET=replace-with-strong-random-session-secret
GOOGLE_API_KEY="your-google-api-key"
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_REQUEST_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=3
RATE_LIMIT_DEFAULT=100/minute
AI_RATE_LIMIT_DEFAULT=30/minute
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=300
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_BASE_URL=http://localhost:3000
